{
  "name": "@arcships/vue-docx",
  "version": "0.2.0",
  "license": "MIT",
  "description": "Vue 3 DOCX viewer and editor components with composable editor state",
  "keywords": ["vue", "vue3", "docx", "word", "viewer", "editor", "components"],
  "homepage": "https://github.com/arcships/agentic-office-ui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/arcships/agentic-office-ui.git",
    "directory": "packages/vue-docx"
  },
  "bugs": {
    "url": "https://github.com/arcships/agentic-office-ui/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": ["./dist/style.css"],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "prepack": "pnpm run build",
    "typecheck": "vue-tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@arcships/docx-core": "^0.2.0"
  },
  "peerDependencies": {
    "vue": ">=3.2.25 <4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^3.3.6"
  }
}
