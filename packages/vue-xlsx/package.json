{
  "name": "@arcships/vue-xlsx",
  "version": "0.4.0",
  "license": "Apache-2.0",
  "description": "Vue 3 XLSX spreadsheet viewer with charts, maps, WebGL, and controller composables",
  "keywords": ["vue", "vue3", "xlsx", "excel", "spreadsheet", "charts", "map", "webgl"],
  "homepage": "https://github.com/arcships/agentic-office-ui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/arcships/agentic-office-ui.git",
    "directory": "packages/vue-xlsx"
  },
  "bugs": {
    "url": "https://github.com/arcships/agentic-office-ui/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./chart": {
      "types": "./dist/optional/chart.d.ts",
      "import": "./dist/chart.js",
      "default": "./dist/chart.js"
    },
    "./map": {
      "types": "./dist/optional/map.d.ts",
      "import": "./dist/map.js",
      "default": "./dist/map.js"
    },
    "./webgl": {
      "types": "./dist/optional/webgl.d.ts",
      "import": "./dist/webgl.js",
      "default": "./dist/webgl.js"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": ["./dist/style.css"],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "prepack": "pnpm run build",
    "typecheck": "vue-tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@dukelib/sheets-wasm": "0.1.17",
    "@arcships/xlsx-core": "^0.4.0",
    "d3-geo": "^3.1.1",
    "d3-hierarchy": "^3.1.2",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "fflate": "^0.8.2",
    "regl": "^2.1.1",
    "topojson-client": "^3.1.0",
    "us-atlas": "^3.0.1",
    "world-atlas": "^2.0.2"
  },
  "peerDependencies": {
    "vue": ">=3.2.25 <4"
  },
  "devDependencies": {
    "@types/d3-geo": "^3.1.0",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/geojson": "^7946.0.16",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^3.3.6"
  }
}
