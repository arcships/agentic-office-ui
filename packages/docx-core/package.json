{
  "name": "@arcships/docx-core",
  "version": "0.2.0",
  "license": "MIT",
  "description": "DOCX document model, layout engine, editing commands, and instance runtime with Worker/WASM support",
  "keywords": ["docx", "word", "document", "viewer", "editor", "wasm", "worker"],
  "homepage": "https://github.com/arcships/agentic-office-ui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/arcships/agentic-office-ui.git",
    "directory": "packages/docx-core"
  },
  "bugs": {
    "url": "https://github.com/arcships/agentic-office-ui/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "default": "./dist/core.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "default": "./dist/runtime.js"
    },
    "./wasm-url": {
      "types": "./dist/wasm-url.d.ts",
      "import": "./dist/wasm-url.js",
      "default": "./dist/wasm-url.js"
    },
    "./assets/docx_wasm_bg.wasm": "./dist/assets/docx_wasm_bg.wasm",
    "./worker": "./dist/docx-import-worker.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "postbuild": "node scripts/normalize-root-worker.mjs && node scripts/prepare-public-resources.mjs",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.8",
    "fast-png": "^8.0.0",
    "fflate": "^0.8.2",
    "utif": "^3.1.0"
  }
}
