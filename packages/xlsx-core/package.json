{
  "name": "@arcships/xlsx-core",
  "version": "0.5.4",
  "license": "Apache-2.0",
  "description": "XLSX workbook model, formulas, charts, images, and instance runtime with Worker/WASM support",
  "keywords": ["xlsx", "excel", "spreadsheet", "workbook", "charts", "wasm", "worker"],
  "homepage": "https://github.com/arcships/agentic-office-ui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/arcships/agentic-office-ui.git",
    "directory": "packages/xlsx-core"
  },
  "bugs": {
    "url": "https://github.com/arcships/agentic-office-ui/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "default": "./dist/core.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "default": "./dist/runtime.js"
    },
    "./wasm-url": {
      "types": "./dist/wasm-url.d.ts",
      "import": "./dist/wasm-url.js",
      "default": "./dist/wasm-url.js"
    },
    "./assets/duke_sheets_wasm_bg.wasm": "./dist/assets/duke_sheets_wasm_bg.wasm",
    "./worker": "./dist/xlsx-worker.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "postbuild": "node scripts/prepare-public-resources.mjs",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "copy-wasm": "node scripts/copy-wasm.mjs"
  },
  "dependencies": {
    "@arcships/office-interaction": "^0.5.4",
    "@dukelib/sheets-wasm": "0.1.17",
    "@xmldom/xmldom": "0.9.10",
    "d3-geo": "^3.1.1",
    "d3-hierarchy": "^3.1.2",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "fflate": "^0.8.2",
    "regl": "^2.1.1",
    "topojson-client": "^3.1.0",
    "us-atlas": "^3.0.1",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@types/d3-geo": "^3.1.0",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/geojson": "^7946.0.16",
    "@types/topojson-client": "^3.1.5",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
